{
  "name": "lark-epic-bot",
  "version": "1.0.0",
  "description": "Cloudflare Worker bot to fetch Epic free games and send via Lark/Feishu",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute epic-games-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute epic-games-db --remote --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.85.0"
  }
}
